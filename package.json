{
  "name": "octoquery",
  "version": "1.0.0",
  "description": "MCP server exposing each configured database as a SQL tool, protected by OAuth 2.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:postgres": "jest mcp-postgres",
    "test:mysql": "jest mcp-mysql",
    "test:mariadb": "jest mcp-mariadb",
    "lint": "biome check && tsc --noEmit",
    "lint:fix": "biome check --write",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "dotenv": "^17.2.0",
    "jose": "^6.0.0",
    "mysql2": "^3.23.0",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.21.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.29",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@testcontainers/mariadb": "^12.0.4",
    "@testcontainers/mysql": "^12.0.4",
    "@testcontainers/postgresql": "^12.0.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.9",
    "@types/supertest": "^7.2.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testTimeout": 120000,
    "maxWorkers": 1
  }
}
