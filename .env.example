# General
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Auth (OAuth 2.0 resource server; works with any OIDC provider).
# Set MCP_AUTH_ENABLED=false for local dev without tokens.
MCP_AUTH_ENABLED=true
# Auth0: https://<tenant>.<region>.auth0.com/ (keep the trailing slash - the
# iss claim includes it). Okta: https://<org>.okta.com/oauth2/default
AUTH_ISSUER=https://your-tenant.eu.auth0.com/
# Auth0: the API Identifier. Okta: the custom auth server audience.
# Optional — when omitted the `aud` claim is not checked.
#AUTH_AUDIENCE=api://octoquery
# Public canonical URL of this service as MCP clients see it (no trailing slash).
BASE_URL=http://localhost:3000

# Default row limit for query results (per-tool override: "maxRows").
MCP_MAX_ROWS=100

# SQL tools are configured in mcp-sql-tools.json (copy mcp-sql-tools.example.json and
# fill in your databases; the real file is gitignored). Optionally point to a
# different location:
# MCP_SQL_TOOLS_FILE=mcp-sql-tools.json
